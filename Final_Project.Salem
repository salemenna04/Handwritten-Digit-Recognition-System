        "def preprocess_image(image):\n",
        "    image = ImageOps.grayscale(image)\n",
        "    image = image.resize((28,28))\n",
        "\n",
        "    image = np.array(image)\n",
        "\n",
        "\n",
        "    image = 255 - image\n",
        "\n",
        "    image = image / 255.0\n",
        "    image = image.reshape(1,28,28,1)\n",
        "\n",
        "    return image"
      ],
