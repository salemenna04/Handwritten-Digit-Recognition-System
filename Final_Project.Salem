    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "project_path = \"/content/Handwritten-Digit-Recognition-System\"\n",
        "os.makedirs(project_path, exist_ok=True)\n",
        "project_path"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 35
        },
        "id": "s7wx_IO1jWbV",
        "outputId": "8fbd65ea-e86f-4ea1-b728-6902257a5d12"
      },
      "execution_count": 11,
